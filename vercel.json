{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "functions": {
    "src/app/api/analyze/route.ts": { "maxDuration": 60 },
    "src/app/api/benchmark/route.ts": { "maxDuration": 60 },
    "src/app/api/enhance/route.ts": { "maxDuration": 60 },
    "src/app/api/guardrails/route.ts": { "maxDuration": 60 },
    "src/app/api/optimize/route.ts": { "maxDuration": 60 },
    "src/app/api/test-prompt/route.ts": { "maxDuration": 60 }
  }
}
